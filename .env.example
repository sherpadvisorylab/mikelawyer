# ============================================
# MIKE - Configurazione Docker / Coolify
# ============================================
# Le variabili BACKEND vanno in backend/.env
# Le variabili FRONTEND vanno nelle env di Coolify
#   (passate come build-arg al frontend)

# ─── BACKEND (backend/.env) ────────────────

PORT=3001
NODE_ENV=production

# URL pubblico del frontend (es. https://mike.tuodominio.com)
FRONTEND_URL=http://localhost:3000

# Genera con: openssl rand -hex 32
DOWNLOAD_SIGNING_SECRET=cambiami-con-32-byte-hex

# ─── SUPABASE ──────────────────────────────
SUPABASE_URL=https://tuo-progetto.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

# ─── STORAGE (usando Supabase Storage via S3 API) ─
# Vedi: Supabase Dashboard > Storage > S3 Settings
# Crea un bucket chiamato ad es. "mike"
R2_ENDPOINT_URL=https://tuo-progetto.supabase.co/storage/v1/s3
R2_ACCESS_KEY_ID=your-s3-access-key
R2_SECRET_ACCESS_KEY=your-s3-secret-key
R2_BUCKET_NAME=mike

# ─── AI PROVIDERS (almeno uno) ─────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── EMAIL (opzionale) ─────────────────────
RESEND_API_KEY=

# ─── SICUREZZA ─────────────────────────────
USER_API_KEYS_ENCRYPTION_SECRET=cambiami-con-una-stringa-lunga-e-casuale

# ─── COURT LISTENER (opzionale) ────────────
COURTLISTENER_API_TOKEN=
COURTLISTENER_BULK_DATA_ENABLED=false

# ════════════════════════════════════════════
# FRONTEND - Variabili per Coolify / build
# ════════════════════════════════════════════
# Queste vanno impostate nelle env di Coolify
# o nel docker-compose, NON in frontend/.env.local
#
# NEXT_PUBLIC_SUPABASE_URL=https://tuo-progetto.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
# NEXT_PUBLIC_API_BASE_URL=https://api.tuodominio.com
